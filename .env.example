# ── Content store (blog, FAQ, slideshows, room-type photos + /admin) ──
# Dedicated content Supabase project (Decision #13). Required.
VITE_CONTENT_SUPABASE_URL=
VITE_CONTENT_SUPABASE_ANON_KEY=

# ── Booking API (PMS project) — required. App crashes at startup without URL. ──
# The public site calls the Hostbase Booking Edge Functions at
# `${VITE_SUPABASE_URL}/functions/v1` (public-property / public-availability /
# public-rates / public-create-reservation). The publishable key is no longer
# used by the site for booking reads, but keep it set so the import doesn't throw.
# Get from https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Booking API tenant fallback — optional, for localhost / Vercel preview only.
# In prod the tenant is resolved from the request Origin. On localhost/preview
# the Origin isn't a tenant domain, so set this to the production host so the
# API can resolve the tenant. Harmless (ignored) in production.
VITE_BOOKING_SERVING_HOST=findyoursuitespot.com

# Google Maps — optional. InteractivePropertyMap renders blank without it.
# Get from https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_MAPS_API_KEY=

# Default property ID — optional/legacy. The Booking API now resolves the
# property server-side; kept only as a fallback for any remaining consumers.
VITE_DEFAULT_PROPERTY_ID=
